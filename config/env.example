# API
PORT=3001
NODE_ENV=development
TRUST_GATEWAY_HEADERS=true

# Registry metadata (spaces, members, publish records)
NOTES_REGISTRY_DB_PATH=./data/registry.db
NOTES_DATA_DIR=./data

# Local clone of the GitHub content monorepo (all spaces under spaces/{slug}/)
NOTES_CONTENT_REPO_PATH=./data/content-repo

# Published read plane (filesystem for local dev without MinIO)
NOTES_PUBLISH_STORAGE_DIR=./data/published
# NOTES_USE_S3_PUBLISH=true
# NOTES_S3_ENDPOINT=http://localhost:9000
# NOTES_S3_BUCKET=harbour-notes-published
# NOTES_S3_ACCESS_KEY_ID=minioadmin
# NOTES_S3_SECRET_ACCESS_KEY=minioadmin
# NOTES_S3_FORCE_PATH_STYLE=true

# GitHub content monorepo (required)
NOTES_GITHUB_REPO=your-org/harbour-notes-content
NOTES_GITHUB_TOKEN=ghp_...
NOTES_GITHUB_BASE_BRANCH=main

# Local dev without Docker — stub identity (set TRUST_GATEWAY_HEADERS=false)
# TRUST_GATEWAY_HEADERS=false
# DEV_USER_ID=alice
# DEV_USER_EMAIL=alice@example.com
# DEV_USER_DISPLAY_NAME=Alice

# UI (Vite)
VITE_HARBOUR_SHELL_URL=https://harbour.local
VITE_API_PROXY_TARGET=http://localhost:3001
