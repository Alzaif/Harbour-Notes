# API
PORT=3001
NODE_ENV=development
NOTES_DB_PATH=./data/notes.db
NOTES_DATA_DIR=./data

# Production behind Traefik ForwardAuth (default)
TRUST_GATEWAY_HEADERS=true

# Local dev without Docker — stub identity (set TRUST_GATEWAY_HEADERS=false)
# TRUST_GATEWAY_HEADERS=false
# DEV_USER_ID=alice
# DEV_USER_EMAIL=alice@example.com
# DEV_USER_DISPLAY_NAME=Alice

# UI (Vite)
VITE_HARBOUR_SHELL_URL=https://harbour.local
VITE_API_PROXY_TARGET=http://localhost:3001
