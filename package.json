{
  "name": "harbour-notes",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "tsx watch --env-file=config/env.example --env-file=.env.local src/main.ts",
    "dev:web": "vite",
    "build": "npm run build:api && npm run build:web",
    "build:api": "esbuild src/main.ts --bundle --platform=node --target=node22 --outfile=dist/main.js --format=esm --packages=external",
    "build:web": "tsc -p tsconfig.app.json --noEmit && vite build",
    "start": "node dist/main.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev:fixtures": "tsx scripts/seed-dev-space.ts",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.api.json --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1082.0",
    "@hono/node-server": "^1.19.6",
    "@tiptap/extension-image": "^3.6.2",
    "@tiptap/react": "^3.6.2",
    "@tiptap/starter-kit": "^3.6.2",
    "better-sqlite3": "^11.10.0",
    "drizzle-orm": "^0.44.5",
    "hono": "^4.10.4",
    "marked": "^18.0.5",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.18.1",
    "simple-git": "^3.36.0",
    "yaml": "^2.9.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "concurrently": "^9.2.1",
    "esbuild": "^0.25.12",
    "jsdom": "^27.0.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.1.12",
    "vitest": "^3.2.4"
  }
}
